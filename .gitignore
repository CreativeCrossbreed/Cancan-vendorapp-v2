# ──────────────────────────────────────────
# Can Can — Monorepo .gitignore
# Two active projects: frontend/ and android/
# ──────────────────────────────────────────

# ── Secrets (NEVER commit) ────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.jks
*.keystore
android/key.properties
api-keys.json

# ── Node / Next.js (frontend/) ────────────
node_modules/
**/node_modules/
.next/
out/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.pnp
.pnp.js
.eslintcache
.npm
coverage/
*.tsbuildinfo
.cache/

# ── Flutter / Dart (android/) ─────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
android/.gradle/
android/local.properties
android/**/build/
android/**/captures/
android/**/.cxx/
android/*.apk
android/*.aab

# ── IDEs ──────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
*.swp
*~

# ── Misc ──────────────────────────────────
*.tgz
*.tar.gz