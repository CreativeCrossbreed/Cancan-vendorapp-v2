{
  "name": "cancan-admin-dashboard",
  "version": "1.0.0",
  "description": "Can Can Water Can Delivery Admin Dashboard - Supabase Integrated",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd frontend && npm run build",
    "install-all": "npm install && cd frontend && npm install",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "security-check": "npm audit && snyk test"
  },
  "keywords": [
    "water-can",
    "delivery",
    "vendor",
    "admin",
    "dashboard",
    "supabase",
    "geofencing",
    "location-services"
  ],
  "author": "Can Can Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "@supabase/supabase-js": "^2.38.4",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^1.7.1",
    "prettier": "^3.1.1",
    "snyk": "^1.1282.0",
    "@types/node": "^20.10.4"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CreativeCrossbreed/vendor_app.git"
  },
  "bugs": {
    "url": "https://github.com/CreativeCrossbreed/vendor_app/issues"
  },
  "homepage": "https://github.com/CreativeCrossbreed/vendor_app#readme",
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/frontend/",
      "/coverage/"
    ]
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:security/recommended"
    ],
    "plugins": [
      "security"
    ],
    "rules": {
      "security/detect-object-injection": "warn",
      "security/detect-non-literal-regexp": "warn",
      "security/detect-possible-timing-attacks": "warn"
    }
  },
  "snyk": {
    "severity": {
      "high": true,
      "medium": true,
      "low": false
    }
  }
}