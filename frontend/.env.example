# =============================================================================
# Can Can frontend — copy to `.env` or `.env.local` and fill values.
# Only variable NAMES matter for the app; comments are optional.
# =============================================================================

# --- Supabase (required for API routes + any client Supabase usage) ----------
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal login: env super-admin (optional if you use admin_users in DB) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=use-a-strong-password

# --- JWT signing for portal sessions (recommended in production) -------------
JWT_SECRET=change-me-to-a-long-random-string

# --- Optional dev bypass: admin@cancan.com / admin123 ------------------------
# DEV_MODE=true

# --- Optional vendor dev auth -------------------------------------------------
# DEV_PHONE=

# --- Optional WhatsApp --------------------------------------------------------
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_SECRET=
# META_APP_SECRET=

# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL is optional if you set SUPABASE_URL (server reads both).
# Use SUPABASE_ANON_KEY (not NEXT_PUBLIC_) so the anon key is not embedded in
# client JS. This app’s API routes use the service role; browser bundle does
# not need the anon key.
# =============================================================================
