# =============================================================================
# Can Can frontend — copy to `.env` or `.env.local` and fill values.
# Only variable NAMES matter for the app; comments are optional.
# =============================================================================

# --- Supabase (required for API routes + any client Supabase usage) ----------
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal login: env super-admin (optional if you use admin_users in DB) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=use-a-strong-password

# --- JWT signing for portal sessions (recommended in production) -------------
JWT_SECRET=change-me-to-a-long-random-string

# --- Optional dev bypass: admin@cancan.com / admin123 ------------------------
# DEV_MODE=true

# --- Optional vendor dev auth -------------------------------------------------
# DEV_PHONE=

# --- Optional WhatsApp --------------------------------------------------------
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_SECRET=
# META_APP_SECRET=

# =============================================================================
# Why NEXT_PUBLIC_* for URL + anon key?
# Next.js only exposes NEXT_PUBLIC_* to the browser. The same URL is used on
# the server for supabaseAdmin — one value, two names would be redundant; we
# use NEXT_PUBLIC_SUPABASE_URL everywhere.
#
# Legacy: SUPABASE_URL and SUPABASE_ANON_KEY are still read by src/lib/supabase.ts
# if NEXT_PUBLIC_* are unset (not recommended — pick one style).
# =============================================================================
